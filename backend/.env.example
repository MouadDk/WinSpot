PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=WinSpot
JWT_SECRET=<GENERATE_A_RANDOM_64_CHAR_HEX_STRING>
ADMIN_SECRET=<STRONG_RANDOM_PASSWORD_32_CHARS>
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>
CLOUDINARY_UPLOAD_FOLDER=winspot/ai-verification
AI_UPLOAD_MAX_BYTES=10485760

# HuggingFace hosted AI services
HF_TOKEN=<YOUR_HUGGINGFACE_TOKEN>
HF_RESTAURANT_CLASSIFIER_ENDPOINT=https://<your-efficientnet-endpoint>.<region>.aws.endpoints.huggingface.cloud
HF_EASYOCR_ENDPOINT=https://<your-easyocr-endpoint>.<region>.aws.endpoints.huggingface.cloud
HF_RESTAURANT_THRESHOLD=0.5
HF_TIMEOUT_MS=60000

# Instagram: Basic Display API was shut down on 2024-12-04.
# Use Instagram API with Instagram Login or Facebook Login for creator/business accounts.
INSTAGRAM_CLIENT_ID=<YOUR_META_APP_ID>
INSTAGRAM_CLIENT_SECRET=<YOUR_META_APP_SECRET>
